      "Bash(go list *)",
      "Bash(go mod *)",
      "Bash(go get *)",
      "Bash(go doc *)",
      "Bash(go build *)",
      "Bash(go vet *)",
      "Bash(go env *)",
      "Bash(actionlint *)",
      "Bash(yamllint *)",
      "Bash(markdownlint-cli2 *)",
